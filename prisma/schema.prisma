datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Profile {
  id        String   @id @default(cuid())
  fullName  String
  headline  String
  tagline   String?
  bio       String?  @db.Text
  photoUrl  String?
  location  String?
  email     String?
  whatsapp  String?
  linkedin  String?
  github    String?
  cvUrl     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Experience {
  id          String    @id @default(cuid())
  role        String
  company     String
  location    String?
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean   @default(false)
  description String?   @db.Text
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([order, startDate])
}

model Project {
  id           String   @id @default(cuid())
  title        String
  description  String?  @db.Text
  category     String?
  portfolioUrl String?
  repoUrl      String?
  imageUrl     String?
  tags         String[]
  featured     Boolean  @default(false)
  isVisible    Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isVisible, featured, order, createdAt])
}

model Skill {
  id        String   @id @default(cuid())
  name      String
  category  String?
  level     Int?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, order, name])
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isVisible, order])
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String?
  content   String   @db.Text
  isRead    Boolean  @default(false)
  ipHash    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model VisitSession {
  id         String   @id @default(cuid())
  visitorId  String
  path       String
  referrer   String?
  device     String?
  country    String?
  durationMs Int      @default(0)
  startedAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([visitorId])
  @@index([startedAt])
}

model RateLimitEvent {
  id        String   @id @default(cuid())
  key       String
  action    String
  createdAt DateTime @default(now())

  @@index([key, action, createdAt])
}
